#!/usr/bin/env bash

# =====================================================
# Modern CLI Helpers
# Keep standard commands intact.
# Troubleshooting should behave exactly as expected.
# =====================================================

# =====================================================
# Listing & Navigation
# =====================================================

# Modern file listing
alias l='eza --icons'
alias ll='eza -lah --icons --git'
alias la='eza -a --icons'
alias lt='eza --tree --icons --level=3'

# Directory shortcuts
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Zoxide shortcut
alias z='zoxide query -i'
alias j='z'

# =====================================================
# File Viewing
# =====================================================

# Bat shortcuts
alias b='bat'
alias bathelp='bat --plain --language=help'

# =====================================================
# Search
# =====================================================

# Fast search
alias f='fd'

# Ripgrep shortcuts
alias rg='rg --smart-case'

# =====================================================
# System Monitoring
# =====================================================

# System info
alias ff='fastfetch'

# Process viewer
alias bt='btop'

# Modern ps
alias pp='procs'

# =====================================================
# Storage
# =====================================================

# Modern disk usage
alias dust='dust'

# Human-readable disk free
alias dfh='df -h'

# =====================================================
# NixOS
# =====================================================

# Open NixOS config
alias nixconf='cd /etc/nixos'

# Rebuild shortcuts
alias ns='sudo nixos-rebuild switch'
alias nt='sudo nixos-rebuild test'
alias nb='sudo nixos-rebuild boot'

# =====================================================
# Git
# =====================================================

alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'

alias gl='git log --oneline --graph --decorate --all'
alias gd='git diff'

# =====================================================
# Safety
# =====================================================

# Interactive delete
alias rm='rm -I'

# =====================================================
# Configs
# =====================================================

alias dots='cd ~/.config'

# =====================================================
# Misc
# =====================================================

alias cls='clear'
alias c='clear'
