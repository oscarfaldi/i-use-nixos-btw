#!/usr/bin/env bash

set -e

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo " Switching Rainier to unstable..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"

sudo nix-channel --remove nixos 2>/dev/null || true

sudo nix-channel --add \
https://channels.nixos.org/nixos-unstable \
nixos

sudo nix-channel --update

echo
echo "✓ Unstable channel enabled."
echo

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo " Next steps"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo
echo "After reboot:"
echo
echo "  1. sudo nixos-rebuild switch"
echo "  2. ./bootstrap"
echo
echo "Rainier will reboot in 10 seconds."
echo "Press Ctrl+C to cancel."
echo

sleep 10

echo "Rebooting Rainier..."
sudo reboot
