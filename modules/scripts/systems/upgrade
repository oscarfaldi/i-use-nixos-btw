#!/usr/bin/env bash

# ==============================================================================
# Rainier System Upgrade & Verification Script
# ==============================================================================
# Description: Upgrades NixOS channels, rebuilds the system configuration,
#              verifies the generation profiles, and diffs package changes.
# ==============================================================================

set -e

SYSTEM_DIR="$HOME/System"
CONFIG="$SYSTEM_DIR/configuration.nix"
STATUS_CACHE="$HOME/.cache/update-status"

print_header() {
    local title="$1"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo " $title"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo
}

main() {
    print_header "Rainier Upgrade Verification"
    
    # Capture the active system profile hash before running the upgrade
    if [ -L /run/current-system ]; then
        BEFORE_PROFILE=$(readlink -f /run/current-system)
    else
        BEFORE_PROFILE="none"
    fi

    echo "Updating channels..."
    sudo nix-channel --update
    echo

    echo "Building and activating system..."
    echo
    sudo nixos-rebuild switch -I nixos-config="$CONFIG"
    echo

    # Capture the system profile hash after the rebuild execution
    AFTER_PROFILE=$(readlink -f /run/current-system)

    print_header "Upgrade Verification Result"

    # Integrity and change detection logic
    if [ "$BEFORE_PROFILE" = "$AFTER_PROFILE" ]; then
        echo "ℹ️ System is already up-to-date. No changes detected in the system profile."
        echo "Current Profile: $AFTER_PROFILE"
        echo "Current" > "$STATUS_CACHE"
    else
        # Physically verify that the newly generated profile directory is valid
        if [ -d "$AFTER_PROFILE" ] && [ -f "$AFTER_PROFILE/init" ]; then
            echo "✅ VERIFICATION SUCCESS: System successfully upgraded to a new profile!"
            echo "Previous: $BEFORE_PROFILE"
            echo "Current:  $AFTER_PROFILE"
            echo
            
            print_header "Updated Packages Diff"
            nvd diff "$BEFORE_PROFILE" "$AFTER_PROFILE" || true
            echo
            
            echo "Current version: $(nixos-version)"
            echo "Current" > "$STATUS_CACHE"
        else
            echo "❌ VERIFICATION FAILED: Profile changed, but the new system path is invalid or incomplete!"
            echo "Expected valid directory at: $AFTER_PROFILE"
            return 1
        fi
    fi
}

# Determine execution context and hand over control to an interactive shell session
if (return 0 2>/dev/null); then
    main "$@"
else
    main "$@"
    echo
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Process finished. Transitioning to interactive session..."
    echo
    exec "$SHELL"
fi
