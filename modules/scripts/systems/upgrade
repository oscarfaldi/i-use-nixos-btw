#!/usr/bin/env bash

# ==============================================================================
# Rainier System Upgrade Script
# 
# Description: Updates Nix channels, rebuilds and activates the system,
#              then displays package changes and version information.
# ==============================================================================

# Exit immediately if a command exits with a non-zero status
set -e

# ------------------------------------------------------------------------------
# Configuration & Variables
# ------------------------------------------------------------------------------
SYSTEM_DIR="$HOME/System"
CONFIG="$SYSTEM_DIR/configuration.nix"
STATUS_CACHE="$HOME/.cache/update-status"

# ------------------------------------------------------------------------------
# UI Helper Functions
# ------------------------------------------------------------------------------
print_header() {
    local title="$1"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo " $title"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo
}

# ------------------------------------------------------------------------------
# Main Execution
# ------------------------------------------------------------------------------
main() {
    print_header "Rainier Upgrade"
    
    echo "Updating channels..."
    sudo nix-channel --update
    echo

    echo "Building and activating system..."
    echo
    
    # Execute NixOS rebuild with explicit configuration path
    # FIX: Combined the multiline command properly using '\'
    sudo nixos-rebuild switch \
        -I nixos-config="$CONFIG"
    echo

    print_header "Updated Packages"

    # Display package diff using nvd (ignores non-zero exit codes via || true)
    nvd diff /nix/var/nix/profiles/system-1-link /run/current-system || true
    echo

    echo "Current version:"
    echo "$(nixos-version)"
    echo
    echo "✓ Upgrade complete."

    # Cache update status for system notifications/status bars
    echo "Current" > "$STATUS_CACHE"
}

# Run the main function
main "$@"
