#!/usr/bin/env bash

# ============================================================
# Waybar System Update Indicator
# Reads the cached update status generated by the
# background update checker and returns a Waybar JSON state.
#
# States:
#   Current - System is up to date
#   Updates - Updates are available
# ============================================================

status_file="$HOME/.cache/update-status"

if [[ -f "$status_file" ]] && grep -q "^Updates$" "$status_file"; then
    echo '{"text":"Updates","class":"updates"}'
else
    echo '{"text":"Current","class":"current"}'
fi
