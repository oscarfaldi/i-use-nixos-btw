#!/usr/bin/env bash

# ============================================================
# Waybar Package Update Indicator
# Reports whether package updates are available by checking
# the current Nix channel and returning a Waybar JSON state.
# States:
#   Current - No updates available
#   Updates - One or more updates available
# ============================================================

output=$(nix-channel --update 2>&1)

if echo "$output" | grep -q "unpacking"; then
    echo '{"text":"Updates","class":"updates"}'
else
    echo '{"text":"Current","class":"current"}'
fi
