#!/usr/bin/env bash

# ============================================================
# Change Preview
# Builds a temporary NixOS generation and displays the
# package and configuration differences before activation.
# ============================================================

set -e

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo " Rainier Change Preview"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo

echo "Building preview generation..."
echo

sudo nixos-rebuild build

echo
echo "Comparing generations..."
echo

nvd diff /run/current-system result
