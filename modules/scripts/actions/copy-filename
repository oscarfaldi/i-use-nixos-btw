#!/usr/bin/env bash

# ==============================================================================
# Script Name: Copy Filename
# Description: Copies the base filename (with extension) to the clipboard.
# ==============================================================================

set -euo pipefail

# Safety Check: Ensure a file was selected
if [ $# -eq 0 ]; then
    notify-send -i dialog-error "Clipboard Error" "No file selected."
    exit 1
fi

# Extract and copy the filename
basename "$1" | wl-copy

# Trigger notification
notify-send -i edit-copy "Clipboard" "Filename copied."
