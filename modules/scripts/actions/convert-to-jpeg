#!/usr/bin/env bash

# ==============================================================================
# Script Name: JPEG Image Converter
# Description: Converts selected images to JPEG format via Thunar Custom Actions
# ==============================================================================

set -euo pipefail

# 0. Safety Check: Ensure at least one file was selected
if [[ $# -eq 0 ]]; then
    notify-send -i dialog-error "JPEG Conversion" "No file selected."
    exit 1
fi

SUCCESS=0
FAILED=0

# 1. Convert every selected image
for FILE in "$@"; do
    DIR="$(dirname "$FILE")"
    NAME="$(basename "$FILE")"
    OUTPUT="${DIR}/${NAME%.*}.jpg"

    if magick \
        -quality 95 \
        "$FILE" \
        "$OUTPUT"
    then
        ((SUCCESS++))
    else
        ((FAILED++))
    fi
done

# 2. Trigger system notification
if (( FAILED == 0 )); then
    notify-send \
        -i image-x-generic \
        "JPEG Conversion" \
        "$SUCCESS image(s) converted successfully."
else
    notify-send \
        -i dialog-warning \
        "JPEG Conversion" \
        "$SUCCESS succeeded, $FAILED failed."
fi
