#!/usr/bin/env bash

set -euo pipefail

FILE="$1"
DIR="$(dirname "$FILE")"
BASENAME=$(basename "$FILE")
FILENAME="${BASENAME%.*}"

ICON="application-pdf"
TITLE="PDF Conversion"

# Define the final output destination path
FINAL_PDF="$DIR/$FILENAME.pdf"

# Execute ONLYOFFICE in headless mode to convert the document
# --new-window and --custom-cmd run the editor processing engine silently
if onlyoffice-desktopeditors \
    --new-window \
    --custom-cmd="deployTextConverter" \
    --all-formats-to="pdf" \
    --argument="{\"fileFrom\":\"$FILE\",\"fileTo\":\"$FINAL_PDF\"}" >/dev/null 2>&1
then
    notify-send \
        -i "$ICON" \
        "$TITLE" \
        "PDF created successfully via ONLYOFFICE."
else
    notify-send \
        -i dialog-error \
        "$TITLE" \
        "Failed to convert file using ONLYOFFICE."
    exit 1
fi
