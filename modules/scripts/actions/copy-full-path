#!/usr/bin/env bash

# ==============================================================================
# Script Name: Copy Full Path
# Description: Copies the absolute system path of the file to the clipboard.
# ==============================================================================

set -euo pipefail

# Safety Check: Ensure a file was selected
if [ $# -eq 0 ]; then
    notify-send -i dialog-error "Clipboard Error" "No file selected."
    exit 1
fi

# Extract and copy the full absolute path
realpath "$1" | wl-copy

# Trigger notification
notify-send -i edit-copy "Clipboard" "Full path copied."
