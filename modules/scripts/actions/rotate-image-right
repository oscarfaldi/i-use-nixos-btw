#!/usr/bin/env bash

# ==============================================================================
# Script Name: Rotate Image Right
# Description: Rotates the selected image 90 degrees clockwise
#              using ImageMagick via Thunar Custom Actions.
# ==============================================================================

set -euo pipefail

# 0. Safety Check: Ensure an image file was selected
if [ $# -eq 0 ]; then
    notify-send -i dialog-error "Image Rotation" "No image selected."
    exit 1
fi

FILE="$1"
DIR="$(dirname "$FILE")"
NAME="$(basename "$FILE")"

# Define output path (creates a new file with '_rotated' suffix)
OUTPUT="${DIR}/${NAME%.*}_rotated.${NAME##*.}"

# 1. Execute rotation
if magick "$FILE" -rotate 90 "$OUTPUT"; then
    notify-send -i image-x-generic "Image Rotation" "Image rotated 90° clockwise."
else
    notify-send -i dialog-error "Image Rotation" "Rotation failed."
fi
