#!/usr/bin/env bash

# ==============================================================================
# Script Name: AVIF Image Converter
# Description: Converts selected images to AVIF format via Thunar Custom Actions
# ==============================================================================

set -euo pipefail

# 0. Safety Check: Ensure at least one file was selected
if [[ $# -eq 0 ]]; then
    notify-send -i dialog-error "AVIF Conversion" "No file selected."
    exit 1
fi

SUCCESS=0
FAILED=0

# 1. Convert every selected image
for FILE in "$@"; do
    DIR="$(dirname "$FILE")"
    NAME="$(basename "$FILE")"
    OUTPUT="${DIR}/${NAME%.*}.avif"

    if avifenc \
        --min 20 \
        --max 30 \
        "$FILE" \
        "$OUTPUT" >/dev/null 2>&1
    then
        ((SUCCESS++))
    else
        ((FAILED++))
    fi
done

# 2. Trigger system notification
if (( FAILED == 0 )); then
    notify-send \
        -i image-x-generic \
        "AVIF Conversion" \
        "$SUCCESS image(s) converted successfully."
else
    notify-send \
        -i dialog-warning \
        "AVIF Conversion" \
        "$SUCCESS succeeded, $FAILED failed."
fi
