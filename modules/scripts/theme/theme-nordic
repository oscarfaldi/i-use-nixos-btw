#!/usr/bin/env bash

# ==============================================================================
# Script: System Theme Configuration (Nordic Variant)
# Description: Sets the system color scheme to dark, applies the Nordic
#              GTK theme, Papirus-Dark icons, and forces Bibata Modern Ice cursor.
# ==============================================================================

echo "Applying Nordic system theme configuration..."

# 1. Set Color Scheme to Prefer Dark (Forces dark mode web/app fallbacks like Chromium)
gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'

# 2. Set GTK Theme to Nordic
gsettings set org.gnome.desktop.interface gtk-theme 'Nordic'

# 3. Set Icon Theme to Papirus-Dark
gsettings set org.gnome.desktop.interface icon-theme 'Papirus-Dark'

# 4. Set Cursor Theme to Bibata-Modern-Ice
gsettings set org.gnome.desktop.interface cursor-theme 'Bibata-Modern-Ice'

echo "Nordic theme configuration applied successfully!"
