#!/usr/bin/env bash

# ============================================================
# Wallpaper Session
# Ensures awww-daemon is running and restores
# the last selected wallpaper on login.
# ============================================================

set -euo pipefail

CURRENT="$HOME/.local/state/current-wallpaper"
WALLPAPER_DIR="$HOME/.config/assets/wallpapers"

mkdir -p "$HOME/.local/state"

# Start awww-daemon if not already running
if ! pgrep -x awww-daemon >/dev/null 2>&1; then
    awww-daemon >/dev/null 2>&1 &
fi

# Restore previous wallpaper
if [[ -f "$CURRENT" ]]; then
    WALLPAPER="$(cat "$CURRENT")"
else
    WALLPAPER="$(
        find "$WALLPAPER_DIR" -type f \( \
            -iname "*.jpg" \
            -o -iname "*.jpeg" \
            -o -iname "*.png" \
            -o -iname "*.webp" \
        \) | shuf -n 1
    )"

    [[ -n "$WALLPAPER" ]] || exit 0
    echo "$WALLPAPER" > "$CURRENT"
fi

[[ -f "$WALLPAPER" ]] || exit 0

awww img "$WALLPAPER" \
    --transition-type grow \
    --transition-duration 1 \
    --transition-fps 60 \
    --transition-step 2
