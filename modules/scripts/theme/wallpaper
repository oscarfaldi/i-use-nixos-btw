#!/usr/bin/env bash

# ============================================================
# Wallpaper Switcher
# Cycles through wallpapers sequentially.
# ============================================================
set -euo pipefail

WALLPAPER_DIR="$HOME/.config/assets/wallpapers"
CURRENT_WALL="$HOME/.local/state/current-wallpaper"

mkdir -p "$HOME/.local/state"

mapfile -t WALLPAPERS < <(
    find "$WALLPAPER_DIR" -type f \( \
        -iname "*.jpg" \
        -o -iname "*.jpeg" \
        -o -iname "*.png" \
        -o -iname "*.webp" \
    \) | sort
)

[[ ${#WALLPAPERS[@]} -gt 0 ]] || exit 0

CURRENT="$(cat "$CURRENT_WALL" 2>/dev/null || true)"
NEXT_INDEX=0

if [[ -n "$CURRENT" ]]; then
    for i in "${!WALLPAPERS[@]}"; do
        if [[ "${WALLPAPERS[$i]}" == "$CURRENT" ]]; then
            NEXT_INDEX=$(( (i + 1) % ${#WALLPAPERS[@]} ))
            break
        fi
    done
fi

SELECTED="${WALLPAPERS[$NEXT_INDEX]}"
echo "$SELECTED" > "$CURRENT_WALL"

awww img "$SELECTED" \
    --transition-type grow \
    --transition-duration 1 \
    --transition-fps 60 \
    --transition-step 2

notify-send \
    "Wallpaper Updated" \
    "$(basename "$SELECTED")"
