#!/usr/bin/env bash

# ============================================================
# Wallpaper Switcher
# Selects a random wallpaper, updates wallust,
# and reloads desktop components.
# ============================================================

set -e

WALLPAPER_DIR="$HOME/.config/assets/wallpapers"

CURRENT_WALL="$HOME/.local/state/current-wallpaper"

mkdir -p "$HOME/.local/state"

mapfile -t WALLPAPERS < <(
    find "$WALLPAPER_DIR" -type f \( \
        -iname "*.jpg" \
        -o -iname "*.jpeg" \
        -o -iname "*.png" \
        -o -iname "*.webp" \
    \) | sort
)

[ "${#WALLPAPERS[@]}" -eq 0 ] && exit 0

CURRENT=$(cat "$CURRENT_WALL" 2>/dev/null || true)

mapfile -t CANDIDATES < <(
    printf '%s\n' "${WALLPAPERS[@]}" |
    grep -vxF "$CURRENT" || true
)

if [ "${#CANDIDATES[@]}" -eq 0 ]; then
    CANDIDATES=("${WALLPAPERS[@]}")
fi

SELECTED=$(printf '%s\n' "${CANDIDATES[@]}" | shuf -n 1)

echo "$SELECTED" > "$CURRENT_WALL"

awww img "$SELECTED" \
    --transition-type grow \
    --transition-duration 1 \
    --transition-fps 60 \
    --transition-step 2

wallust run "$SELECTED"

pkill -SIGUSR2 waybar 2>/dev/null || true

notify-send \
    "Wallpaper Updated" \
    "$(basename "$SELECTED")"
