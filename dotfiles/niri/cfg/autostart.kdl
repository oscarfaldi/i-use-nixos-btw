// ────────────── Startup Applications ──────────────
// https://github.com/YaLTeR/niri/wiki/Configuration:-Miscellaneous#spawn-sh-at-startup

	spawn-at-startup "/run/current-system/sw/libexec/polkit-gnome-authentication-agent-1"
	spawn-at-startup "waybar"
	spawn-at-startup "mako"
	spawn-at-startup "swayidle"
	spawn-at-startup "awww-daemon"

	spawn-at-startup "chromium" "--app=https://chatgpt.com"
	spawn-at-startup "chromium" "--app=https://web.whatsapp.com"
	spawn-at-startup "chromium" "--app=https://mail.google.com"
