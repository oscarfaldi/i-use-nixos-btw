#!/usr/bin/env bash

set -e

STATE="$HOME/.local/state/current-theme"
CURRENT_WALL="$HOME/.local/state/current-wallpaper"

THEME=$(cat "$STATE" 2>/dev/null || echo graphite)

WALLPAPER_DIR="/etc/nixos/assets/themes/$THEME/wallpapers"

mapfile -t WALLPAPERS < <(
    find "$WALLPAPER_DIR" -type f \( \
        -iname "*.jpg" \
        -o -iname "*.jpeg" \
        -o -iname "*.png" \
        -o -iname "*.webp" \
    \) | sort
)

[ "${#WALLPAPERS[@]}" -eq 0 ] && exit 0

CURRENT=$(cat "$CURRENT_WALL" 2>/dev/null || true)

while true; do

    SELECTED="${WALLPAPERS[RANDOM % ${#WALLPAPERS[@]}]}"

    [ "$SELECTED" != "$CURRENT" ] && break

    [ "${#WALLPAPERS[@]}" -eq 1 ] && break

done

echo "$SELECTED" > "$CURRENT_WALL"

awww img "$SELECTED" \
    --transition-type grow \
    --transition-duration 1 \
    --transition-fps 60 \
    --transition-step 2

notify-send \
    "Wallpaper Updated" \
    "$THEME · $(basename "$SELECTED")"
