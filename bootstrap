#!/usr/bin/env bash

set -Eeuo pipefail

REPO_DIR="/etc/nixos"


# ============================================================
# Helpers
# ============================================================

fail() {
    echo
    echo "✗ $1"
    echo
    exit 1
}

section() {
    echo
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo " $1"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo
}

success() {
    echo
    echo "✓ $1"
    echo
}


# ============================================================
# Header
# ============================================================

section "Rainier Bootstrap"

echo "Repository : $REPO_DIR"
echo "User       : $USER"
echo "Home       : $HOME"


# ============================================================
# Repository Validation
# ============================================================

section "Validating Repository"

[ -d "$REPO_DIR" ] || fail "Repository not found: $REPO_DIR"

[ -d "$REPO_DIR/.config" ] || fail "Missing $REPO_DIR/.config"

success "Repository verified"


# ============================================================
# User Configuration
# ============================================================

section "Installing User Configuration"

mkdir -p "$HOME/.config"

CONFIG_SOURCE_COUNT=$(find "$REPO_DIR/.config" -mindepth 1 | wc -l)

[ "$CONFIG_SOURCE_COUNT" -gt 0 ] || fail ".config repository is empty"

cp -rf "$REPO_DIR/.config/." "$HOME/.config/"

# Verify critical configs
for dir in niri waybar fuzzel fastfetch; do
    [ -e "$HOME/.config/$dir" ] || fail "Missing config: $dir"
done

CONFIG_INSTALLED_COUNT=$(find "$HOME/.config" -mindepth 1 | wc -l)

echo "Repository entries : $CONFIG_SOURCE_COUNT"
echo "Installed entries  : $CONFIG_INSTALLED_COUNT"

success "User configuration installed"


# ============================================================
# Preparing Theme System
# ============================================================

section "Preparing Theme System"

mkdir -p "$HOME/.local/state"
mkdir -p "$HOME/.cache/theme"

if [ ! -f "$HOME/.local/state/current-theme" ]; then
    echo graphite > "$HOME/.local/state/current-theme"
fi

generate-theme

[ -f "$HOME/.cache/theme/waybar.css" ] \
    || fail "waybar.css generation failed"

[ -f "$HOME/.cache/theme/ghostty.theme" ] \
    || fail "ghostty.theme generation failed"

success "Theme system ready"


# ============================================================
# Shell Environment
# ============================================================

# Install Rainier shell configuration

section "Configuring Shell"

if [ ! -f "$REPO_DIR/.config/zshrc" ]; then
    fail "Missing .config/zshrc"
fi

cp -f "$REPO_DIR/.config/zshrc" "$HOME/.zshrc"

success "Shell configured"


# ============================================================
# User Directories
# ============================================================

section "Checking User Directories"

# Create and verify in one pass
for dir in Documents Downloads Music Pictures Videos Games Templates; do
    mkdir -p "$HOME/$dir"
    [ -d "$HOME/$dir" ] || fail "Directory missing: $dir"
done

success "User directories ready"


# ============================================================
# System Modules
# ============================================================

section "Verifying System Commands"

command -v generate-theme >/dev/null \
    || fail "generate-theme command missing"

command -v theme-toggle >/dev/null \
    || fail "theme-toggle command missing"

command -v wallpaper >/dev/null \
    || fail "wallpaper command missing"

command -v wallpaperd >/dev/null \
    || fail "wallpaperd command missing"

command -v screenshot >/dev/null \
    || fail "screenshot command missing"

command -v clean >/dev/null \
    || fail "clean command missing"

command -v rebuild >/dev/null \
    || fail "rebuild command missing"

command -v rebuild-boot >/dev/null \
    || fail "rebuild-boot command missing"

success "System modules verified"


# ============================================================
# Summary
# ============================================================

section "Bootstrap Complete"

echo "Rainier is configured."
echo
echo "Installed:"
echo " • User configuration"
echo " • Shell environment"
echo " • User directories"
echo
echo "Verified:"
echo " • .config"
echo " • .zshrc"
echo
echo "System ready."
echo
echo "Reboot required to start a fresh session."
echo
echo "Rebooting in 10 seconds..."
echo "Press Ctrl+C to cancel."
echo

sleep 10

sudo reboot
