#!/usr/bin/env bash

set -e

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo " Rainier Rebuild"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo

echo "Building system..."
echo

sudo nixos-rebuild switch

echo
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo " Rebuild Complete"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo

echo "Hostname : rainier"
echo "Version  : $(nixos-version)"
echo

echo "✓ System successfully activated."
