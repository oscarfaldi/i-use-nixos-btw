#!/usr/bin/env bash

set -e

WALLPAPER_DIR="/etc/nixos/assets/wallpapers"

mapfile -t WALLPAPERS < <(
    find "$WALLPAPER_DIR" -type f \( \
        -iname "*.jpg" \
        -o -iname "*.jpeg" \
        -o -iname "*.png" \
        -o -iname "*.webp" \
    \) | sort
)

# No wallpapers found

[ "${#WALLPAPERS[@]}" -eq 0 ] && exit 0

# Current wallpaper

CURRENT=$(
    awww query 2>/dev/null |
    sed -n 's/.*image: //p' |
    head -n1
)

# Select a different wallpaper

while true; do
    SELECTED="${WALLPAPERS[RANDOM % ${#WALLPAPERS[@]}]}"

    [ "${#WALLPAPERS[@]}" -eq 1 ] && break

    [ "$SELECTED" != "$CURRENT" ] && break
done

# Apply wallpaper

awww img "$SELECTED" \
    --transition-type grow \
    --transition-duration 1 \
    --transition-fps 60 \
    --transition-step 2

# Notification

notify-send \
    "Wallpaper Updated" \
    "$(basename "$SELECTED")"
