#!/usr/bin/env bash

set -e

# ============================================================
# Screenshot Directory
# ============================================================

MONTH_DIR="$(date '+%B %Y')"
BASE_DIR="$HOME/Pictures/Screenshots/$MONTH_DIR"

mkdir -p "$BASE_DIR"

# ============================================================
# Screenshot Filename
# ============================================================

FILE="$BASE_DIR/$(date '+%Y-%m-%d_%H-%M-%S').png"

# ============================================================
# Region Selection
# ============================================================

REGION=$(slurp) || exit 0

# ============================================================
# Capture
# ============================================================

grim -g "$REGION" "$FILE"

# ============================================================
# Notification
# ============================================================

notify-send \
    "Screenshot Saved" \
    "$(basename "$FILE")"
