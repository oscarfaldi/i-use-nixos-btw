#!/usr/bin/env bash

set -e

# Monthly screenshot directory

MONTH_DIR="$(date '+%B %Y')"
BASE_DIR="$HOME/Pictures/Screenshots/$MONTH_DIR"

mkdir -p "$BASE_DIR"

# Timestamped filename

FILE="$BASE_DIR/$(date '+%Y-%m-%d_%H-%M-%S').png"

# Select region (exit silently if cancelled)

REGION=$(slurp) || exit 0

# Capture screenshot

grim -g "$REGION" "$FILE"

# Notification

notify-send 
"Screenshot Saved" 
"$(basename "$FILE")"
